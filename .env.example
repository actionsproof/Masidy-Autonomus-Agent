# Masidy Agent Environment Variables Example

# Core Node Setup
NODE_ENV=development
PORT=3000
CLIENT_URL=http://localhost:3000
SESSION_SECRET=masidy-agent-session-random-key-123456

# Database
DATABASE_URL=postgres://user:password@localhost:5432/masidy_db

# Anthropic Claude API (Primary AI Engine)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_MODEL=claude-haiku-4-5

# Gemini AI API (Alternative / Local developer runtime fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub OAuth credentials
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Vercel deployment credentials
VERCEL_TOKEN=your_vercel_token_here
VERCEL_DEPLOYMENT_TOKEN=your_vercel_deployment_token_here
VERCEL_PROJECT_ID=your_vercel_project_id_here
VERCEL_TEAM_ID=your_vercel_team_id_here

# Search Engines (Used for browsing & planning tools)
SERPER_API_KEY=your_serper_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Deployment domain options
DEPLOY_DOMAIN=masidy.app
